generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AnimeShow {
  id                     String    @id @default(cuid())
  metadataProvider       String
  metadataId             String
  title                  String
  originalTitle          String?
  overview               String?
  posterUrl              String?
  firstAiredAt           DateTime?
  status                 String    @default("PLAN_TO_WATCH")
  episodesTotal          Int?
  genres                 String?
  studios                String?
  rating                 Float?
  notes                  String?
  airingStatus           String?
  nextEpisodeNum         Int?
  nextAiringAt           DateTime?
  lastEpisodeNum         Int?
  lastAiredAt            DateTime?
  airingRefreshedAt      DateTime?
  upToDateEpisodeNum     Int?
  upToDateAiredAt        DateTime?
  upToDateStale          Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  reminders              EpisodeReminder[]

  @@unique([metadataProvider, metadataId])
}

model EpisodeReminder {
  id            String    @id @default(cuid())
  animeShowId   String
  episodeNumber Int?
  airsAt        DateTime
  dismissedAt   DateTime?
  createdAt     DateTime  @default(now())
  animeShow     AnimeShow @relation(fields: [animeShowId], references: [id], onDelete: Cascade)

  @@unique([animeShowId, airsAt])
}

model AppUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
