generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AnimeShow {
  id                     String    @id @default(cuid())
  metadataProvider       String
  metadataId             String
  sourceProvider         String?
  sourceId               String?
  title                  String
  originalTitle          String?
  overview               String?
  posterUrl              String?
  firstAiredAt           DateTime?
  status                 String    @default("PLAN_TO_WATCH")
  episodesTotal          Int?
  genres                 String?
  studios                String?
  rating                 Float?
  notes                  String?
  airingStatus           String?
  nextEpisodeNum         Int?
  nextAiringAt           DateTime?
  lastEpisodeNum         Int?
  lastAiredAt            DateTime?
  airingRefreshedAt      DateTime?
  upToDateEpisodeNum     Int?
  upToDateAiredAt        DateTime?
  upToDateStale          Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  reminders              EpisodeReminder[]
  childRatings           AnimeChildRating[]

  @@unique([metadataProvider, metadataId])
  @@unique([sourceProvider, sourceId])
}

model EpisodeReminder {
  id            String    @id @default(cuid())
  animeShowId   String
  episodeNumber Int?
  airsAt        DateTime
  dismissedAt   DateTime?
  createdAt     DateTime  @default(now())
  animeShow     AnimeShow @relation(fields: [animeShowId], references: [id], onDelete: Cascade)

  @@unique([animeShowId, airsAt])
}

model AnimeChildRating {
  id            String    @id @default(cuid())
  animeShowId   String
  kind          String
  key           String
  providerName  String?
  providerId    String?
  seasonNumber  Int?
  episodeNumber Int?
  title         String
  posterUrl     String?
  airDate       DateTime?
  rating        Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  animeShow     AnimeShow @relation(fields: [animeShowId], references: [id], onDelete: Cascade)

  @@unique([animeShowId, kind, key])
  @@index([animeShowId, kind])
}

model AppUser {
  id               String   @id @default(cuid())
  username         String   @unique
  passwordHash     String
  profileImageData String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
