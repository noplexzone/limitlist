# Authentication (required)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_SECRET=change-this-to-a-random-32-char-string
# Set true only when serving the app over HTTPS. Leave false for plain HTTP LAN/Docker testing.
AUTH_COOKIE_SECURE=false

# Database
# For local dev (relative path, auto-created by Prisma):
DATABASE_URL="file:./dev.db"
# For Docker (use /data mount):
# DATABASE_URL="file:/data/anime-tracker.db"

# Metadata provider (required for search)
# Get your key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
